diff --git a/include/spdlog/fmt/bundled/base.h b/include/spdlog/fmt/bundled/base.h
index 62764942..f6c2055a 100644
--- a/include/spdlog/fmt/bundled/base.h
+++ b/include/spdlog/fmt/bundled/base.h
@@ -111,7 +111,17 @@
 #endif
 
 // Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.
-#if !defined(__cpp_lib_is_constant_evaluated)
+// vkm patch: Emscripten's upstream clang (verified on emsdk 6.0.2 and 4.0.10; not
+// reproducible with native Apple Clang 17) and newer AppleClang (verified on the
+// macOS 26 SDK toolchain) both fail to evaluate FMT_STRING's compile-time
+// format-string check as a constant expression ("call to consteval function ... is
+// not a constant expression"), even though they otherwise report consteval support.
+// Force the non-consteval (runtime) path on these targets; this is the only known
+// way to unblock the build, since fmt has no public override for FMT_USE_CONSTEVAL.
+// Re-check on future Emscripten/Apple toolchain/fmt upgrades.
+#if defined(__EMSCRIPTEN__) || defined(__APPLE__)
+#  define FMT_USE_CONSTEVAL 0
+#elif !defined(__cpp_lib_is_constant_evaluated)
 #  define FMT_USE_CONSTEVAL 0
 #elif FMT_CPLUSPLUS < 201709L
 #  define FMT_USE_CONSTEVAL 0
